generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CommonStatus {
  ACTIVE
  INACTIVE
}

enum CrawlStatus {
  QUEUED
  RUNNING
  FINISHED
  FAILED
}

model User {
  id           String             @id @default(uuid())
  username     String             @unique
  passwordHash String
  status       CommonStatus       @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?
  userRoles    UserRole[]
  notes        AgentNote[]
  parserLinks  UserParserSource[]
}

model Role {
  id        String     @id @default(uuid())
  code      String     @unique
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userRoles UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model SiteProvider {
  id          String               @id @default(uuid())
  key         String               @unique
  name        String
  baseUrl     String
  status      CommonStatus         @default(ACTIVE)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  resources   MediaResource[]
  configs     SiteProviderConfig[]
  crawlJobs   CrawlJob[]
}

model SiteProviderConfig {
  id             String       @id @default(uuid())
  siteProviderId String
  configKey      String
  configValue    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  siteProvider   SiteProvider @relation(fields: [siteProviderId], references: [id])

  @@unique([siteProviderId, configKey])
}

model MediaResource {
  id             String            @id @default(uuid())
  siteProviderId String
  externalId     String
  title          String
  category       String?
  detailUrl      String?
  coverUrl       String?
  status         CommonStatus      @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  siteProvider   SiteProvider      @relation(fields: [siteProviderId], references: [id])
  episodes       MediaEpisode[]
  tags           MediaResourceTag[]

  @@unique([siteProviderId, externalId])
  @@index([title])
}

model MediaEpisode {
  id              String       @id @default(uuid())
  mediaResourceId String
  episodeName     String
  playPageUrl     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  mediaResource   MediaResource @relation(fields: [mediaResourceId], references: [id])
}

model MediaTag {
  id        String            @id @default(uuid())
  name      String            @unique
  createdAt DateTime          @default(now())
  resources MediaResourceTag[]
}

model MediaResourceTag {
  id              String        @id @default(uuid())
  mediaResourceId String
  mediaTagId      String
  mediaResource   MediaResource @relation(fields: [mediaResourceId], references: [id])
  mediaTag        MediaTag      @relation(fields: [mediaTagId], references: [id])

  @@unique([mediaResourceId, mediaTagId])
}

model ParserSource {
  id          String             @id @default(uuid())
  name        String
  endpoint    String
  ownerType   String
  status      CommonStatus       @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userLinks   UserParserSource[]
  resolveLogs ResolveLog[]
}

model UserParserSource {
  id             String       @id @default(uuid())
  userId         String
  parserSourceId String
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])
  parserSource   ParserSource @relation(fields: [parserSourceId], references: [id])

  @@unique([userId, parserSourceId])
}

model ResolveLog {
  id             String       @id @default(uuid())
  parserSourceId String
  targetUrl      String
  success        Boolean
  message        String?
  createdAt      DateTime     @default(now())
  parserSource   ParserSource @relation(fields: [parserSourceId], references: [id])
}

model CrawlJob {
  id             String       @id @default(uuid())
  siteProviderId String
  status         CrawlStatus  @default(QUEUED)
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime     @default(now())
  siteProvider   SiteProvider @relation(fields: [siteProviderId], references: [id])
  logs           CrawlJobLog[]
}

model CrawlJobLog {
  id         String   @id @default(uuid())
  crawlJobId String
  level      String
  message    String
  createdAt  DateTime @default(now())
  crawlJob   CrawlJob @relation(fields: [crawlJobId], references: [id])
}

model AgentNote {
  id        String   @id @default(uuid())
  userId    String?
  taskKey   String
  content   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([taskKey])
}

model SkillTemplate {
  id        String   @id @default(uuid())
  name      String
  scenario  String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
