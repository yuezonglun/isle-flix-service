{
  "openapi": "3.0.0",
  "paths": {
    "/auth/login": {
      "post": {
        "description": "使用用户名和密码登录，返回 JWT accessToken。",
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokenResponseDto"
                }
              }
            }
          }
        },
        "summary": "用户登录",
        "tags": [
          "认证模块"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "description": "刷新并返回新的 accessToken。",
        "operationId": "AuthController_refresh",
